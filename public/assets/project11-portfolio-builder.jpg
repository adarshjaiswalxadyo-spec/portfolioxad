<!-- Portfolio Builder Project Placeholder -->
<!-- Replace with actual screenshot of your Portfolio Builder project -->
<svg width="800" height="600" viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="portfolioGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#8b5cf6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#6366f1;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="800" height="600" fill="#f8fafc"/>
  
  <!-- Main Interface -->
  <rect x="0" y="0" width="800" height="80" fill="url(#portfolioGrad)"/>
  <text x="400" y="50" font-family="Arial" font-size="28" font-weight="bold" fill="white" text-anchor="middle">Portfolio Builder</text>
  
  <!-- Sidebar -->
  <rect x="0" y="80" width="200" height="520" fill="#f1f5f9"/>
  
  <!-- Template Options -->
  <rect x="20" y="120" width="160" height="60" rx="5" fill="white" stroke="#8b5cf6" stroke-width="2"/>
  <text x="100" y="155" font-family="Arial" font-size="14" fill="#334155" text-anchor="middle">Modern Template</text>
  
  <rect x="20" y="200" width="160" height="60" rx="5" fill="white" stroke="#e2e8f0" stroke-width="1"/>
  <text x="100" y="235" font-family="Arial" font-size="14" fill="#334155" text-anchor="middle">Classic Template</text>
  
  <rect x="20" y="280" width="160" height="60" rx="5" fill="white" stroke="#e2e8f0" stroke-width="1"/>
  <text x="100" y="315" font-family="Arial" font-size="14" fill="#334155" text-anchor="middle">Creative Template</text>
  
  <!-- Preview Area -->
  <rect x="220" y="120" width="560" height="400" rx="10" fill="white" stroke="#e2e8f0" stroke-width="2"/>
  
  <!-- Mini Portfolio Preview -->
  <rect x="240" y="140" width="520" height="80" fill="url(#portfolioGrad)"/>
  <text x="500" y="185" font-family="Arial" font-size="24" font-weight="bold" fill="white" text-anchor="middle">John Doe</text>
  
  <rect x="240" y="240" width="520" height="60" fill="#f8fafc"/>
  <text x="250" y="275" font-family="Arial" font-size="14" fill="#334155">Web Developer & Designer</text>
  
  <rect x="240" y="320" width="160" height="80" rx="5" fill="#fef3c7"/>
  <text x="320" y="365" font-family="Arial" font-size="12" fill="#92400e" text-anchor="middle">Projects</text>
  
  <rect x="420" y="320" width="160" height="80" rx="5" fill="#dbeafe"/>
  <text x="500" y="365" font-family="Arial" font-size="12" fill="#1e40af" text-anchor="middle">Skills</text>
  
  <rect x="600" y="320" width="160" height="80" rx="5" fill="#dcfce7"/>
  <text x="680" y="365" font-family="Arial" font-size="12" fill="#166534" text-anchor="middle">Contact</text>
  
  <!-- Action Buttons -->
  <rect x="240" y="440" width="120" height="40" rx="5" fill="#8b5cf6"/>
  <text x="300" y="465" font-family="Arial" font-size="14" font-weight="bold" fill="white" text-anchor="middle">Preview</text>
  
  <rect x="380" y="440" width="120" height="40" rx="5" fill="#10b981"/>
  <text x="440" y="465" font-family="Arial" font-size="14" font-weight="bold" fill="white" text-anchor="middle">Deploy</text>
  
  <rect x="520" y="440" width="120" height="40" rx="5" fill="#ef4444"/>
  <text x="580" y="465" font-family="Arial" font-size="14" font-weight="bold" fill="white" text-anchor="middle">Export</text>
</svg>
