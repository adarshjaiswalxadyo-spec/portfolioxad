<!-- 2023 Journey Photo -->
<!-- Replace with actual photo from 2023 -->
<svg width="400" height="200" viewBox="0 0 400 200" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="journey2023" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#8b5cf6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#6366f1;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="400" height="200" fill="url(#journey2023)"/>
  
  <!-- Content -->
  <rect x="50" y="50" width="300" height="100" rx="10" fill="rgba(30, 41, 59, 0.8)"/>
  <text x="200" y="90" font-family="Arial" font-size="24" font-weight="bold" fill="white" text-anchor="middle">2023</text>
  <text x="200" y="120" font-family="Arial" font-size="16" fill="white" text-anchor="middle">Professional Projects</text>
  <text x="200" y="140" font-family="Arial" font-size="14" fill="#94a3b8" text-anchor="middle">Certifications & Freelancing</text>
</svg>
