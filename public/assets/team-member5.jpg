<!-- Alex Kumar Team Member Photo -->
<!-- Replace with actual photo -->
<svg width="300" height="300" viewBox="0 0 300 300" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="memberGrad5" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#8b5cf6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#6366f1;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="300" height="300" fill="url(#memberGrad5)"/>
  
  <!-- Profile Circle -->
  <circle cx="150" cy="150" r="120" fill="#1e293b"/>
  
  <!-- Person Icon -->
  <circle cx="150" cy="120" r="40" fill="#8b5cf6"/>
  <path d="M 150 170 Q 150 180, 150 190 Q 120 200, 100 230 L 200 230 Q 180 200, 150 190" fill="#8b5cf6"/>
  
  <!-- Initials -->
  <text x="150" y="130" font-family="Arial" font-size="32" font-weight="bold" fill="white" text-anchor="middle">AK</text>
</svg>
