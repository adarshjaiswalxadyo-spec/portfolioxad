<!-- Fitness Tracker Project Placeholder -->
<!-- Replace with actual screenshot of your Fitness Tracker project -->
<svg width="800" height="600" viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="fitnessGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ef4444;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f97316;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="800" height="600" fill="#ffffff"/>
  
  <!-- Header -->
  <rect x="0" y="0" width="800" height="80" fill="url(#fitnessGrad)"/>
  <text x="400" y="50" font-family="Arial" font-size="28" font-weight="bold" fill="white" text-anchor="middle">Fitness Tracker</text>
  
  <!-- Stats Cards -->
  <rect x="50" y="120" width="160" height="120" rx="10" fill="#fef2f2" stroke="#ef4444" stroke-width="2"/>
  <text x="130" y="150" font-family="Arial" font-size="14" fill="#991b1b" text-anchor="middle">Calories Burned</text>
  <text x="130" y="190" font-family="Arial" font-size="32" font-weight="bold" fill="#dc2626" text-anchor="middle">2,450</text>
  <text x="130" y="220" font-family="Arial" font-size="12" fill="#991b1b" text-anchor="middle">Today</text>
  
  <rect x="230" y="120" width="160" height="120" rx="10" fill="#fef3c7" stroke="#f59e0b" stroke-width="2"/>
  <text x="310" y="150" font-family="Arial" font-size="14" fill="#92400e" text-anchor="middle">Steps</text>
  <text x="310" y="190" font-family="Arial" font-size="32" font-weight="bold" fill="#d97706" text-anchor="middle">8,432</text>
  <text x="310" y="220" font-family="Arial" font-size="12" fill="#92400e" text-anchor="middle">Today</text>
  
  <rect x="410" y="120" width="160" height="120" rx="10" fill="#dcfce7" stroke="#22c55e" stroke-width="2"/>
  <text x="490" y="150" font-family="Arial" font-size="14" fill="#166534" text-anchor="middle">Active Minutes</text>
  <text x="490" y="190" font-family="Arial" font-size="32" font-weight="bold" fill="#16a34a" text-anchor="middle">45</text>
  <text x="490" y="220" font-family="Arial" font-size="12" fill="#166534" text-anchor="middle">Today</text>
  
  <rect x="590" y="120" width="160" height="120" rx="10" fill="#dbeafe" stroke="#3b82f6" stroke-width="2"/>
  <text x="670" y="150" font-family="Arial" font-size="14" fill="#1e40af" text-anchor="middle">Heart Rate</text>
  <text x="670" y="190" font-family="Arial" font-size="32" font-weight="bold" fill="#2563eb" text-anchor="middle">72</text>
  <text x="670" y="220" font-family="Arial" font-size="12" fill="#1e40af" text-anchor="middle">BPM</text>
  
  <!-- Workout Plan -->
  <rect x="50" y="270" width="700" height="280" rx="10" fill="#f8fafc" stroke="#e2e8f0" stroke-width="2"/>
  <text x="400" y="300" font-family="Arial" font-size="20" font-weight="bold" fill="#334155" text-anchor="middle">Today's Workout Plan</text>
  
  <!-- Workout Items -->
  <rect x="80" y="330" width="200" height="60" rx="5" fill="white" stroke="#ef4444" stroke-width="2"/>
  <text x="90" y="355" font-family="Arial" font-size="14" fill="#334155">🏃 Morning Run</text>
  <text x="90" y="375" font-family="Arial" font-size="12" fill="#64748b">30 minutes • 5km</text>
  
  <rect x="300" y="330" width="200" height="60" rx="5" fill="white" stroke="#22c55e" stroke-width="2"/>
  <text x="310" y="355" font-family="Arial" font-size="14" fill="#334155">💪 Strength Training</text>
  <text x="310" y="375" font-family="Arial" font-size="12" fill="#64748b">45 minutes • Upper body</text>
  
  <rect x="520" y="330" width="200" height="60" rx="5" fill="white" stroke="#3b82f6" stroke-width="2"/>
  <text x="530" y="355" font-family="Arial" font-size="14" fill="#334155">🧘 Yoga</text>
  <text x="530" y="375" font-family="Arial" font-size="12" fill="#64748b">20 minutes • Flexibility</text>
  
  <!-- Progress Bar -->
  <rect x="80" y="420" width="640" height="30" rx="15" fill="#e2e8f0"/>
  <rect x="80" y="420" width="384" height="30" rx="15" fill="url(#fitnessGrad)"/>
  <text x="400" y="440" font-family="Arial" font-size="14" font-weight="bold" fill="white" text-anchor="middle">60% Complete</text>
  
  <!-- Action Button -->
  <rect x="320" y="470" width="160" height="50" rx="25" fill="url(#fitnessGrad)"/>
  <text x="400" y="500" font-family="Arial" font-size="16" font-weight="bold" fill="white" text-anchor="middle">Start Workout</text>
</svg>
