<!-- Task Manager Pro Project Placeholder -->
<!-- Replace with actual screenshot of your Task Manager Pro project -->
<svg width="800" height="600" viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="taskGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#10b981;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#059669;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="800" height="600" fill="#f8fafc"/>
  
  <!-- Header -->
  <rect x="0" y="0" width="800" height="80" fill="url(#taskGrad)"/>
  <text x="400" y="50" font-family="Arial" font-size="32" font-weight="bold" fill="white" text-anchor="middle">Task Manager Pro</text>
  
  <!-- Task Columns -->
  <rect x="50" y="120" width="220" height="400" rx="10" fill="#f1f5f9" stroke="#e2e8f0" stroke-width="2"/>
  <text x="160" y="150" font-family="Arial" font-size="18" font-weight="bold" fill="#334155" text-anchor="middle">To Do</text>
  
  <rect x="290" y="120" width="220" height="400" rx="10" fill="#f1f5f9" stroke="#e2e8f0" stroke-width="2"/>
  <text x="400" y="150" font-family="Arial" font-size="18" font-weight="bold" fill="#334155" text-anchor="middle">In Progress</text>
  
  <rect x="530" y="120" width="220" height="400" rx="10" fill="#f1f5f9" stroke="#e2e8f0" stroke-width="2"/>
  <text x="640" y="150" font-family="Arial" font-size="18" font-weight="bold" fill="#334155" text-anchor="middle">Done</text>
  
  <!-- Task Cards -->
  <rect x="70" y="180" width="180" height="60" rx="5" fill="white" stroke="#10b981" stroke-width="2"/>
  <text x="80" y="205" font-family="Arial" font-size="14" fill="#334155">Design Homepage</text>
  <text x="80" y="225" font-family="Arial" font-size="12" fill="#64748b">High Priority</text>
  
  <rect x="310" y="180" width="180" height="60" rx="5" fill="white" stroke="#f59e0b" stroke-width="2"/>
  <text x="320" y="205" font-family="Arial" font-size="14" fill="#334155">API Integration</text>
  <text x="320" y="225" font-family="Arial" font-size="12" fill="#64748b">In Progress</text>
  
  <rect x="550" y="180" width="180" height="60" rx="5" fill="white" stroke="#10b981" stroke-width="2"/>
  <text x="560" y="205" font-family="Arial" font-size="14" fill="#334155">Database Setup</text>
  <text x="560" y="225" font-family="Arial" font-size="12" fill="#64748b">Completed</text>
  
  <!-- Add Task Button -->
  <rect x="320" y="540" width="160" height="40" rx="20" fill="url(#taskGrad)"/>
  <text x="400" y="565" font-family="Arial" font-size="16" font-weight="bold" fill="white" text-anchor="middle">+ Add Task</text>
</svg>
