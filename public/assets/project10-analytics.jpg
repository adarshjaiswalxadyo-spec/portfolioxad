<!-- Social Media Analytics Project Placeholder -->
<!-- Replace with actual screenshot of your Social Media Analytics project -->
<svg width="800" height="600" viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="analyticsGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f59e0b;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#ef4444;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="800" height="600" fill="#ffffff"/>
  
  <!-- Header -->
  <rect x="0" y="0" width="800" height="80" fill="url(#analyticsGrad)"/>
  <text x="400" y="50" font-family="Arial" font-size="28" font-weight="bold" fill="white" text-anchor="middle">Social Media Analytics</text>
  
  <!-- Dashboard Cards -->
  <rect x="50" y="120" width="160" height="100" rx="10" fill="#fef3c7" stroke="#f59e0b" stroke-width="2"/>
  <text x="130" y="150" font-family="Arial" font-size="14" fill="#92400e" text-anchor="middle">Followers</text>
  <text x="130" y="190" font-family="Arial" font-size="28" font-weight="bold" fill="#92400e" text-anchor="middle">12.5K</text>
  
  <rect x="230" y="120" width="160" height="100" rx="10" fill="#dbeafe" stroke="#3b82f6" stroke-width="2"/>
  <text x="310" y="150" font-family="Arial" font-size="14" fill="#1e40af" text-anchor="middle">Engagement</text>
  <text x="310" y="190" font-family="Arial" font-size="28" font-weight="bold" fill="#1e40af" text-anchor="middle">8.2%</text>
  
  <rect x="410" y="120" width="160" height="100" rx="10" fill="#dcfce7" stroke="#22c55e" stroke-width="2"/>
  <text x="490" y="150" font-family="Arial" font-size="14" fill="#166534" text-anchor="middle">Reach</text>
  <text x="490" y="190" font-family="Arial" font-size="28" font-weight="bold" fill="#166534" text-anchor="middle">45.8K</text>
  
  <rect x="590" y="120" width="160" height="100" rx="10" fill="#fce7f3" stroke="#ec4899" stroke-width="2"/>
  <text x="670" y="150" font-family="Arial" font-size="14" fill="#9f1239" text-anchor="middle">Likes</text>
  <text x="670" y="190" font-family="Arial" font-size="28" font-weight="bold" fill="#9f1239" text-anchor="middle">89.3K</text>
  
  <!-- Chart Area -->
  <rect x="50" y="250" width="700" height="300" rx="10" fill="#f8fafc" stroke="#e2e8f0" stroke-width="2"/>
  
  <!-- Bar Chart -->
  <rect x="100" y="450" width="60" height="80" fill="#f59e0b"/>
  <rect x="200" y="420" width="60" height="110" fill="#3b82f6"/>
  <rect x="300" y="400" width="60" height="130" fill="#22c55e"/>
  <rect x="400" y="430" width="60" height="100" fill="#ec4899"/>
  <rect x="500" y="410" width="60" height="120" fill="#8b5cf6"/>
  <rect x="600" y="440" width="60" height="90" fill="#ef4444"/>
  
  <!-- Chart Labels -->
  <text x="130" y="480" font-family="Arial" font-size="12" fill="#64748b" text-anchor="middle">Mon</text>
  <text x="230" y="480" font-family="Arial" font-size="12" fill="#64748b" text-anchor="middle">Tue</text>
  <text x="330" y="480" font-family="Arial" font-size="12" fill="#64748b" text-anchor="middle">Wed</text>
  <text x="430" y="480" font-family="Arial" font-size="12" fill="#64748b" text-anchor="middle">Thu</text>
  <text x="530" y="480" font-family="Arial" font-size="12" fill="#64748b" text-anchor="middle">Fri</text>
  <text x="630" y="480" font-family="Arial" font-size="12" fill="#64748b" text-anchor="middle">Sat</text>
</svg>
