<!-- AI Chat Assistant Project Placeholder -->
<!-- Replace with actual screenshot of your AI Chat Assistant project -->
<svg width="800" height="600" viewBox="0 0 800 600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="aiGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#6366f1;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#8b5cf6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#ec4899;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="800" height="600" fill="#0f172a"/>
  
  <!-- Chat Interface -->
  <rect x="50" y="50" width="700" height="500" rx="20" fill="#1e293b" stroke="#6366f1" stroke-width="2"/>
  
  <!-- Chat Header -->
  <rect x="50" y="50" width="700" height="80" rx="20" fill="url(#aiGrad)"/>
  <text x="400" y="95" font-family="Arial" font-size="24" font-weight="bold" fill="white" text-anchor="middle">AI Chat Assistant</text>
  
  <!-- Chat Messages -->
  <rect x="80" y="150" width="250" height="60" rx="10" fill="#334155"/>
  <text x="90" y="185" font-family="Arial" font-size="14" fill="white">Hello! How can I help you?</text>
  
  <rect x="470" y="220" width="250" height="60" rx="10" fill="#6366f1"/>
  <text x="480" y="255" font-family="Arial" font-size="14" fill="white">Tell me about your features</text>
  
  <rect x="80" y="290" width="250" height="60" rx="10" fill="#334155"/>
  <text x="90" y="325" font-family="Arial" font-size="14" fill="white">I'm an AI-powered assistant!</text>
  
  <!-- Input Area -->
  <rect x="80" y="480" width="640" height="50" rx="10" fill="#334155" stroke="#6366f1" stroke-width="1"/>
  <text x="90" y="510" font-family="Arial" font-size="14" fill="#94a3b8">Type your message...</text>
  
  <!-- AI Icon -->
  <circle cx="400" cy="300" r="80" fill="url(#aiGrad)" opacity="0.2"/>
  <text x="400" y="310" font-family="Arial" font-size="48" fill="url(#aiGrad)" text-anchor="middle">🤖</text>
</svg>
